<Window x:Class="TekTomato.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" 
        Height="500" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource PrimaryBackground}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="TekTomato Settings"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryForeground}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- Settings Content ScrollViewer -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Timer Durations Section -->
                <GroupBox Header="Timer Durations (minutes)" Style="{StaticResource GroupBoxStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Work Duration -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="Work:" 
                                       VerticalAlignment="Center" 
                                       Margin="15,0,5,0"
                                       Foreground="{StaticResource PrimaryForeground}"
                                       Width="60"/>
                            <TextBox x:Name="WorkDurationBox"
                                     Text="{Binding WorkDurationMinutes, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80"
                                     Style="{StaticResource TextBoxStyle}"/>
                            <TextBlock Text="minutes" 
                                       VerticalAlignment="Center" 
                                       Margin="5,0"
                                       Foreground="{StaticResource SecondaryForeground}"/>
                        </StackPanel>

                        <!-- Short Break Duration -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <TextBlock Text="Short break:" 
                                       VerticalAlignment="Center" 
                                       Margin="15,0,5,0"
                                       Foreground="{StaticResource PrimaryForeground}"
                                       Width="60"/>
                            <TextBox x:Name="ShortBreakBox"
                                     Text="{Binding ShortBreakMinutes, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80"
                                     Style="{StaticResource TextBoxStyle}"/>
                            <TextBlock Text="minutes" 
                                       VerticalAlignment="Center" 
                                       Margin="5,0"
                                       Foreground="{StaticResource SecondaryForeground}"/>
                        </StackPanel>

                        <!-- Long Break Duration -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="Long break:" 
                                       VerticalAlignment="Center" 
                                       Margin="15,0,5,0"
                                       Foreground="{StaticResource PrimaryForeground}"
                                       Width="60"/>
                            <TextBox x:Name="LongBreakBox"
                                     Text="{Binding LongBreakMinutes, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80"
                                     Style="{StaticResource TextBoxStyle}"/>
                            <TextBlock Text="minutes" 
                                       VerticalAlignment="Center" 
                                       Margin="5,0"
                                       Foreground="{StaticResource SecondaryForeground}"/>
                        </StackPanel>

                        <!-- Long Break Interval -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal">
                            <TextBlock Text="Pomodoros until long break:" 
                                       VerticalAlignment="Center" 
                                       Margin="15,0,5,0"
                                       Foreground="{StaticResource PrimaryForeground}"
                                       Width="60"/>
                            <TextBox x:Name="LongBreakIntervalBox"
                                     Text="{Binding LongBreakInterval, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80"
                                     Style="{StaticResource TextBoxStyle}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Sound Section -->
                <GroupBox Header="Sound" Style="{StaticResource GroupBoxStyle}">
                    <StackPanel>
                        <ComboBox x:Name="SoundComboBox"
                                  ItemsSource="{Binding AvailableSounds}"
                                  SelectedItem="{Binding SelectedSound, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource ComboBoxStyle}"/>
                        
                        <Button Content="🔊 Test Sound"
                                Command="{Binding TestSoundCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                Margin="0,10,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- Appearance Section -->
                <GroupBox Header="Appearance" Style="{StaticResource GroupBoxStyle}">
                    <StackPanel>
                        <!-- Theme Selection -->
                        <TextBlock Text="Theme:"
                                   Foreground="{StaticResource PrimaryForeground}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <ComboBox x:Name="ThemeComboBox"
                                  ItemsSource="{Binding AvailableThemes}"
                                  SelectedItem="{Binding SelectedTheme, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource ComboBoxStyle}"/>

                        <!-- Opacity Slider -->
                        <TextBlock Text="Background Opacity:"
                                   Foreground="{StaticResource PrimaryForeground}"
                                   FontWeight="SemiBold"
                                   Margin="0,15,0,5"/>
                        
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="OpacitySlider"
                                    Minimum="20"
                                    Maximum="100"
                                    Value="{Binding BackgroundOpacityPercent, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource SliderStyle}"/>
                            
                            <TextBlock x:Name="OpacityLabel"
                                       Text="80%"
                                       Foreground="{StaticResource PrimaryForeground}"
                                       Width="45"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Reset Button -->
                <Button x:Name="ResetDefaultsButton"
                        Content="↺ Reset to Defaults"
                        Style="{StaticResource ActionButtonStyle}"
                        Margin="0,20,0,0"
                        Click="OnResetDefaultsClick"/>
            </Grid>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Style="{StaticResource ActionButtonStyle}"
                    Command="{Binding CancelCommand}"/>
            
            <Button x:Name="SaveButton"
                    Content="Save Changes"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
    </Grid>
</Window>