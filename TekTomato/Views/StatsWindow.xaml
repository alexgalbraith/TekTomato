<Window x:Class="TekTomato.Views.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        Title="Statistics" 
        Height="500" Width="780"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryBackground}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Title and Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="📊 Statistics Dashboard"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryForeground}"/>
            
            <ComboBox x:Name="DateRangeComboBox"
                      Grid.Column="1"
                      ItemsSource="{Binding SelectedRange, Mode=OneWay}"
                      SelectionChanged="OnDateRangeChanged"
                      HorizontalAlignment="Right"
                      Margin="20,0,0,0"
                      Width="150"
                      Style="{StaticResource ComboBoxStyle}"/>
        </StackPanel>

        <!-- Chart View Toggle -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,10">
            <RadioButton Content="📅 Daily View"
                         IsChecked="{Binding IsWeeklyView, Mode=OneWay}"
                         Style="{StaticResource RadioButtonStyle}"/>
            
            <RadioButton Content="📈 Weekly View"
                         IsChecked="{Binding IsWeeklyView, Mode=OneWay}"
                         Style="{StaticResource RadioButtonStyle}"
                         Margin="20,0,0,0"/>
        </StackPanel>

        <!-- Main Content: Heatmap and Line Chart -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: Calendar Heatmap -->
            <GroupBox Header="Activity Heatmap" Style="{StaticResource GroupBoxStyle}" Grid.Column="0">
                <skia:SKElement x:Name="HeatmapCanvas" 
                                PaintSurface="OnHeatmapPaintSurface"/>
            </GroupBox>

            <!-- Right Column: Focus Minutes Line Chart -->
            <GroupBox Header="Focus Minutes" Style="{StaticResource GroupBoxStyle}" Grid.Column="1">
                <lvc:CartesianChart x:Name="LineChart"
                                    Series="{Binding LineChartSeries}"
                                    XAxes="{Binding XAxes}">
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Minutes"/>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </GroupBox>
        </Grid>

        <!-- Footer: Refresh Button -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,15,0,0">
            
            <Button Content="🔄 Refresh Data"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource ActionButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>