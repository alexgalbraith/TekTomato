<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Colour Palette for Dark Theme -->
    <Color x:Key="PrimaryBackground">#1a1a1a</Color>
    <Color x:Key="SecondaryBackground">#2d2d2d</Color>
    <Color x:Key="TertiaryBackground">#333333</Color>
    
    <Color x:Key="PrimaryForeground">#ffffff</Color>
    <Color x:Key="SecondaryForeground">#999999</Color>
    <Color x:Key="DisabledForeground">#666666</Color>
    
    <Color x:Key="AccentGreen">#4caf50</Color>
    <Color x:Key="AccentBlue">#2196f3</Color>
    <Color x:Key="AccentDanger">#e53935</Color>
    <Color x:Key="AccentWarning">#ff9800</Color>
    
    <Color x:Key="ButtonBackground">#3d3d3d</Color>
    <Color x:Key="ButtonHover">#555555</Color>
    <Color x:Key="ButtonBorder">#444444</Color>
    
    <Color x:Key="WindowBackground">#1a1a1a</Color>
    <Color x:Key="OverlayBackground">#000000</Color>

</ResourceDictionary>