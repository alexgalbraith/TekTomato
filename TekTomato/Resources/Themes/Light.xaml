<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Colour Palette for Light Theme -->
    <Color x:Key="PrimaryBackground">#f5f5f5</Color>
    <Color x:Key="SecondaryBackground">#e0e0e0</Color>
    <Color x:Key="TertiaryBackground">#d6d6d6</Color>
    
    <Color x:Key="PrimaryForeground">#212121</Color>
    <Color x:Key="SecondaryForeground">#666666</Color>
    <Color x:Key="DisabledForeground">#999999</Color>
    
    <Color x:Key="AccentGreen">#388e3c</Color>
    <Color x:Key="AccentBlue">#1976d2</Color>
    <Color x:Key="AccentDanger">#d32f2f</Color>
    <Color x:Key="AccentWarning">#f57c00</Color>
    
    <Color x:Key="ButtonBackground">#dddddd</Color>
    <Color x:Key="ButtonHover">#cccccc</Color>
    <Color x:Key="ButtonBorder">#bbbbbb</Color>
    
    <Color x:Key="WindowBackground">#f5f5f5</Color>
    <Color x:Key="OverlayBackground">#ffffff</Color>

</ResourceDictionary>