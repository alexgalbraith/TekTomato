<Application x:Class="TekTomato.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="OnStartup"
             Exit="OnExit">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Common Styles (Fonts, Shapes, Templates) -->
                <ResourceDictionary Source="Resources/Themes/Common.xaml" />
                
                <!-- Default Theme: Dark Mode -->
                <!-- Will be swapped at runtime by ThemeService -->
                <ResourceDictionary Source="Resources/Themes/Dark.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>